{
  "manifest_version": 2,
  "name": "Camoufox RDP Input",
  "version": "1.0",
  "description": "Trusted input dispatch via nsIDOMWindowUtils",
  "browser_specific_settings": {
    "gecko": {
      "id": "camoufox-rdp-input@local",
      "strict_min_version": "120.0"
    }
  },
  "experiment_apis": {
    "nativeInput": {
      "schema": "experiment/schema.json",
      "parent": {
        "scopes": ["addon_parent"],
        "paths": [["nativeInput"]],
        "script": "experiment/api.js"
      }
    }
  },
  "permissions": [
    "tabs",
    "<all_urls>",
    "activeTab",
    "webRequest",
    "webRequestBlocking",
    "proxy"
  ],
  "background": {
    "scripts": ["background.js"],
    "persistent": true
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["cursor.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ]
}
