+ public:
+  static void SetSeed(uint32_t aUserContextId, uint32_t aSeed);
+  static uint32_t GetSeed(uint32_t aUserContextId);
+  static void ApplyCanvasNoise(uint8_t* data, uint32_t width, uint32_t height,
+                                uint32_t seed);
